generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Category {
  id        String     @id @default(uuid())
  name      String
  color     String     // 예: "#FF5733"
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // 참조 관계 (1:N)
  events    Event[]
  bookmarks Bookmark[]

  @@map("categories")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  authorName  String

  // 카테고리가 삭제되는 것을 대비해 SetNull 옵션 권장 (혹은 Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // 선택적 위치 정보 (직접 입력 혹은 Bookmark와 연동)
  locationId  String?
  locationName String?
  latitude    Float?
  longitude   Float?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("events")
}

model Bookmark {
  id           String    @id @default(uuid())
  customName   String?   // 사용자가 지정한 이름
  placeName    String    // 구글맵 등의 실제 장소명
  
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  memo         String?
  googleMapUrl String?   // 상세 링크
  
  // 필수 위치 정보
  latitude     Float
  longitude    Float
  isPinned     Boolean   @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("bookmarks")
}

model Notepad {
  id        String   @id @default("main") // "main" 이라는 단일 PK 사용 권장
  content   String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("notepad")
}

model Settings {
  id        String   @id @default("main")
  startDate DateTime?
  endDate   DateTime?
  updatedAt DateTime @updatedAt

  @@map("settings")
}
